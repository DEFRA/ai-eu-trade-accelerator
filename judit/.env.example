OPENAI_API_KEY=
LITELLM_MASTER_KEY=judit-dev-key

JUDIT_LLM_BASE_URL=http://127.0.0.1:4000/v1
JUDIT_LLM_API_KEY=judit-dev-key

JUDIT_MODEL_LOCAL_EXTRACT=local_extract
JUDIT_MODEL_LOCAL_CLASSIFY=local_classify
JUDIT_MODEL_FRONTIER_REASON=frontier_reason
JUDIT_MODEL_FRONTIER_WRITEUP=frontier_writeup

JUDIT_DATABASE_URL=sqlite:///./judit.db

# Next.js (apps/web): optional absolute path to the API ops export root — enables
# proposition explorer “repair failed extraction chunks” (must match the server’s export dir).
# NEXT_PUBLIC_JUDIT_OPS_EXPORT_DIR=

# Optional: browser origins the API allows for CORS (comma-separated). Defaults cover
# localhost/127.0.0.1 on ports 3000–3001 for Next.js dev (including port fallback).
# CORS_ALLOWED_ORIGINS=http://localhost:3002,http://127.0.0.1:3002
