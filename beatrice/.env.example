ANTHROPIC_API_KEY=your-anthropic-api-key-here

LITELLM_MASTER_KEY=your-litellm-master-key

LLM_BASE_URL=http://127.0.0.1:4000/v1
LLM_API_KEY=your-litellm-key

MODEL_GUIDANCE_EXTRACT=claude_sonnet
MODEL_GUIDANCE_CLASSIFY=claude_sonnet
MODEL_GUIDANCE_SUMMARISE=claude_sonnet

MODEL_EMBED=local_embed

# BERTScore model (roberta-large is the default; deberta-xlarge-mnli gives better NLI-based scores)
MODEL_BERT_SCORE=microsoft/deberta-xlarge-mnli
#MODEL_BERT_SCORE=roberta-large

# Optional: HuggingFace token for gated models
#HF_TOKEN=your-hf-token

# Cache paths (defaults shown)
#CLASSIFY_CACHE_PATH=/tmp/beatrice/classify-cache.json
#EMBEDDINGS_CACHE_PATH=/tmp/beatrice/law-embeddings-cache.json
#EXTRACT_CACHE_PATH=/tmp/beatrice/extract-cache.json
#SUMMARISE_CACHE_PATH=/tmp/beatrice/summarise-cache.json
